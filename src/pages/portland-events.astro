---
import Layout from '../layouts/Layout.astro';

const calendars = [
  {
    title: 'Portland Events',
    description: null,
    src: '6218570f10546f6f03748bbd25adcde299bfd55ef4741d8d1520e79653d9c9f6%40group.calendar.google.com',
    color: '%23616161',
  },
  {
    title: 'Farmers Markets',
    description: 'Portland has farmers markets almost every day of the week.',
    src: '560e859bd2c7b5dfd2262cb6f28389921434606cec955e7ec75f02df9fd2138a%40group.calendar.google.com',
    color: '%230B8043',
  },
];

const triviaSrcs = [
  '561e4a90958248768cba407c23d37f1293e28f3749bc14de503d258fc03a48c7%40group.calendar.google.com', // N & NE
  '088af359972350285c1e5bccda5fb38c349d0597d7c795ef3d1c21d7b973e457%40group.calendar.google.com', // NW & SW
  '441feafdb38c603cde09cd9a60e4f8ed10be90a21eb26dee01db64d0c8594a88%40group.calendar.google.com', // SE
  'ac0a6fedb05274655f5e68e9ec26c3f9b341866ae0feed97dd703e94f164a0bf%40group.calendar.google.com', // Further Out
];

const pedalpalozzaSrc = 'd11s65r5vlq540k2aicdm8c7ndrp6dsl%40import.calendar.google.com';

function calUrl(src: string | string[], mobile = false) {
  const srcParams = Array.isArray(src) ? src.map(s => `&src=${s}`).join('') : `&src=${src}`;
  return `https://calendar.google.com/calendar/embed?height=600&wkst=1&ctz=America%2FLos_Angeles&bgcolor=%23ffffff${mobile ? '&mode=AGENDA' : ''}${srcParams}`;
}
---

<Layout
  title="Portland Events"
  description="Curated Google Calendars for Portland events, farmers markets, trivia nights, and more."
  pageClass="page-events"
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <header class="mb-10">
      <h1 class="text-4xl font-semibold text-stone-900 mb-3" style="font-family: var(--font-serif)">Portland Events</h1>
      <p class="text-stone-500 text-lg max-w-2xl">
        A curated set of calendars for things happening around Portland — events I find interesting,
        farmers markets, trivia nights by neighborhood, and more. Portland staples (like the Naked Bike Ride) are marked in purple.
      </p>
    </header>

    <!-- Resources -->
    <div class="mb-10 p-5 bg-white rounded-2xl border border-stone-100 shadow-sm">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-stone-400 mb-3">Good sources for more</h2>
      <ul class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-stone-600">
        <li><a href="https://everout.com/portland/" target="_blank" rel="noopener" class="hover:text-orange-600 underline underline-offset-2">EverOut</a></li>
        <li><a href="https://www.instagram.com/michelevenlee/" target="_blank" rel="noopener" class="hover:text-orange-600 underline underline-offset-2">@michelevenlee on Instagram</a></li>
        <li><a href="https://www.travelportland.com/events/" target="_blank" rel="noopener" class="hover:text-orange-600 underline underline-offset-2">Travel Portland</a></li>
        <li><a href="https://portlandlivingonthecheap.com/" target="_blank" rel="noopener" class="hover:text-orange-600 underline underline-offset-2">Portland Living on the Cheap</a></li>
        <li><a href="https://www.pdxpipeline.com/" target="_blank" rel="noopener" class="hover:text-orange-600 underline underline-offset-2">PDX Pipeline</a></li>
        <li><a href="https://pc-pdx.com/show-guide/" target="_blank" rel="noopener" class="hover:text-orange-600 underline underline-offset-2">PC-PDX</a></li>
        <li><a href="https://pdxparent.com/" target="_blank" rel="noopener" class="hover:text-orange-600 underline underline-offset-2">PDX Parent</a></li>
      </ul>
    </div>

    <!-- Portland Events + Farmers Markets -->
    {calendars.map(cal => (
      <section class="mb-12">
        <h2 class="text-2xl font-semibold text-stone-900 mb-2" style="font-family: var(--font-serif)">{cal.title}</h2>
        {cal.description && <p class="text-stone-500 text-sm mb-4">{cal.description}</p>}
        <div class="relative w-full rounded-2xl overflow-hidden border border-stone-100 shadow-sm" style="padding-bottom: 60%; height: 0;">
          <iframe
            class="hidden md:block absolute top-0 left-0 w-full h-full"
            src={calUrl(cal.src)}
            style="border: 0"
            frameborder="0"
            scrolling="no"
          ></iframe>
          <iframe
            class="md:hidden absolute top-0 left-0 w-full h-full"
            src={calUrl(cal.src, true)}
            style="border: 0"
            frameborder="0"
            scrolling="no"
          ></iframe>
        </div>
      </section>
    ))}

    <!-- Trivia Nights -->
    <section class="mb-12">
      <h2 class="text-2xl font-semibold text-stone-900 mb-2" style="font-family: var(--font-serif)">Trivia Nights</h2>
      <p class="text-stone-500 text-sm mb-4">Trivia is big in Portland. All neighborhoods in one calendar — toggle areas on/off using the checkboxes in the bottom-left of the embed.</p>
      <div class="relative w-full rounded-2xl overflow-hidden border border-stone-100 shadow-sm" style="padding-bottom: 60%; height: 0;">
        <iframe
          class="hidden md:block absolute top-0 left-0 w-full h-full"
          src={calUrl(triviaSrcs)}
          style="border: 0"
          frameborder="0"
          scrolling="no"
        ></iframe>
        <iframe
          class="md:hidden absolute top-0 left-0 w-full h-full"
          src={calUrl(triviaSrcs, true)}
          style="border: 0"
          frameborder="0"
          scrolling="no"
        ></iframe>
      </div>
    </section>

    <!-- Pedalpalooza / Shift Community Calendar -->
    <section class="mb-12">
      <h2 class="text-2xl font-semibold text-stone-900 mb-2" style="font-family: var(--font-serif)">Pedalpalooza</h2>
      <p class="text-stone-500 text-sm mb-4">The Shift community calendar — bike events year-round, with Pedalpalooza in the summer.</p>
      <div class="relative w-full rounded-2xl overflow-hidden border border-stone-100 shadow-sm" style="padding-bottom: 60%; height: 0;">
        <iframe
          class="hidden md:block absolute top-0 left-0 w-full h-full"
          src={calUrl(pedalpalozzaSrc)}
          style="border: 0"
          frameborder="0"
          scrolling="no"
        ></iframe>
        <iframe
          class="md:hidden absolute top-0 left-0 w-full h-full"
          src={calUrl(pedalpalozzaSrc, true)}
          style="border: 0"
          frameborder="0"
          scrolling="no"
        ></iframe>
      </div>
    </section>

    <!-- Portland Favorites Map -->
    <section class="mb-12">
      <h2 class="text-2xl font-semibold text-stone-900 mb-2" style="font-family: var(--font-serif)">Portland Favorites Map</h2>
      <p class="text-stone-500 text-sm mb-4">A map of places I like around the city.</p>
      <div class="relative w-full rounded-2xl overflow-hidden border border-stone-100 shadow-sm" style="padding-bottom: 60%; height: 0;">
        <iframe
          class="absolute top-0 left-0 w-full h-full"
          src="https://www.google.com/maps/d/u/0/embed?mid=1PPFjj6o3PLraMpY1BxJsboW1ZiITlGI&ehbc=2E312F&noprof=1"
          style="border: 0"
          frameborder="0"
          scrolling="no"
        ></iframe>
      </div>
    </section>

    <!-- Feedback -->
    <section class="p-6 bg-white rounded-2xl border border-stone-100 shadow-sm">
      <h2 class="text-lg font-semibold text-stone-900 mb-1" style="font-family: var(--font-serif)">Know something I'm missing?</h2>
      <p class="text-stone-500 text-sm mb-3">If you have a suggestion for an event, calendar, or place to add, reach out.</p>
      <a href="mailto:ian.p.rosado@gmail.com?subject=Portland Events Suggestion" class="inline-block px-5 py-2 bg-orange-600 text-white text-sm font-medium rounded-full hover:bg-orange-700 transition-colors">
        Send a suggestion
      </a>
    </section>
  </div>
</Layout>
