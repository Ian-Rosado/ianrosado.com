---
const calendars = [
  {
    title: 'Portland Events',
    description: 'A hand-curated calendar of interesting events happening around Portland — festivals, markets, performances, and one-of-a-kind local happenings. Annual Portland staples like the World Naked Bike Ride and Adult Soapbox Derby are marked in purple so you never miss them. You can add any of these calendars to your own Google Calendar using the + button in the bottom-right corner of the embed.',
    src: '6218570f10546f6f03748bbd25adcde299bfd55ef4741d8d1520e79653d9c9f6%40group.calendar.google.com',
    color: '%23F4511E',
  },
  {
    title: 'Live Music',
    description: 'Live music events around Portland — concerts, shows, and performances across the city. Spun off from the main events calendar to keep things from getting crowded.',
    src: '34ae96ffcf119eb4dbf6acf86b0886273efeb8a702ed6e9267ef3d24f0e9a1f7%40group.calendar.google.com',
    color: '%238E24AA',
  },
  {
    title: 'Farmers Markets',
    description: "Portland has one of the best farmers market scenes in the country — with markets running nearly every day of the week across the metro area. From the iconic PSU Saturday Market in the South Park Blocks to neighborhood markets in Beaverton, Hillsboro, and beyond, there's almost always a market nearby.",
    src: '560e859bd2c7b5dfd2262cb6f28389921434606cec955e7ec75f02df9fd2138a%40group.calendar.google.com',
    color: '%230B8043',
  },
];

const triviaSrcs = [
  '561e4a90958248768cba407c23d37f1293e28f3749bc14de503d258fc03a48c7%40group.calendar.google.com',
  '088af359972350285c1e5bccda5fb38c349d0597d7c795ef3d1c21d7b973e457%40group.calendar.google.com',
  '441feafdb38c603cde09cd9a60e4f8ed10be90a21eb26dee01db64d0c8594a88%40group.calendar.google.com',
  'ac0a6fedb05274655f5e68e9ec26c3f9b341866ae0feed97dd703e94f164a0bf%40group.calendar.google.com',
];

const pedalpalozzaSrc = 'd11s65r5vlq540k2aicdm8c7ndrp6dsl%40import.calendar.google.com';

function calUrl(src: string | string[], mobile = false, opts: { color?: string; showTitle?: boolean } = {}) {
  const srcParams = Array.isArray(src) ? src.map(s => `&src=${s}`).join('') : `&src=${src}`;
  const colorParam = opts.color ? `&color=${opts.color}` : '';
  const titleParam = opts.showTitle === false ? '&showTitle=0' : '';
  return `https://calendar.google.com/calendar/embed?height=600&wkst=1&ctz=America%2FLos_Angeles&bgcolor=%23ffffff${mobile ? '&mode=AGENDA' : ''}${titleParam}${srcParams}${colorParam}`;
}
---

<div class="max-w-5xl mx-auto px-4 py-12">
  <!-- Portland Events + Farmers Markets -->
  {calendars.map(cal => (
    <section class="mb-12">
      <h2 class="text-2xl font-semibold text-stone-900 mb-2" style="font-family: var(--font-serif)">{cal.title}</h2>
      {cal.description && <p class="text-stone-500 text-sm mb-4">{cal.description}</p>}
      <div class="cal-frame relative w-full rounded-2xl overflow-hidden border border-stone-100 shadow-sm">
        <iframe class="hidden md:block absolute top-0 left-0 w-full h-full" src={calUrl(cal.src, false, { color: cal.color })} style="border: 0" frameborder="0" scrolling="no"></iframe>
        <iframe class="md:hidden absolute top-0 left-0 w-full h-full" src={calUrl(cal.src, true, { color: cal.color })} style="border: 0" frameborder="0" scrolling="no"></iframe>
      </div>
    </section>
  ))}

  <!-- Trivia Nights -->
  <section class="mb-12">
    <h2 class="text-2xl font-semibold text-stone-900 mb-2" style="font-family: var(--font-serif)">Trivia Nights</h2>
    <p class="text-stone-500 text-sm mb-4">Trivia nights are a Portland institution — bars and venues across the city run weekly games, and they fill up fast. This calendar covers N &amp; NE, NW &amp; SW, SE Portland, and surrounding areas all in one view. Toggle neighborhoods on and off using the checkboxes in the bottom-left of the embed. Arrive early — popular spots book out quickly.</p>
    <div class="cal-frame relative w-full rounded-2xl overflow-hidden border border-stone-100 shadow-sm">
      <iframe class="hidden md:block absolute top-0 left-0 w-full h-full" src={calUrl(triviaSrcs, true, { showTitle: false })} style="border: 0" frameborder="0" scrolling="no"></iframe>
      <iframe class="md:hidden absolute top-0 left-0 w-full h-full" src={calUrl(triviaSrcs, true, { showTitle: false })} style="border: 0" frameborder="0" scrolling="no"></iframe>
    </div>
  </section>

  <!-- Pedalpalooza -->
  <section class="mb-12">
    <h2 class="text-2xl font-semibold text-stone-900 mb-2" style="font-family: var(--font-serif)">Pedalpalooza</h2>
    <p class="text-stone-500 text-sm mb-4">Portland is one of the most bike-friendly cities in the country, and Pedalpalooza is its annual celebration of cycling culture. Organized by the Shift community, it features hundreds of rides over several weeks each summer. This calendar tracks Shift bike events year-round — not just Pedalpalooza season.</p>
    <div class="cal-frame relative w-full rounded-2xl overflow-hidden border border-stone-100 shadow-sm">
      <iframe class="hidden md:block absolute top-0 left-0 w-full h-full" src={calUrl(pedalpalozzaSrc)} style="border: 0" frameborder="0" scrolling="no"></iframe>
      <iframe class="md:hidden absolute top-0 left-0 w-full h-full" src={calUrl(pedalpalozzaSrc, true)} style="border: 0" frameborder="0" scrolling="no"></iframe>
    </div>
  </section>

  <!-- Resources -->
  <div class="mb-10 p-5 bg-white rounded-2xl border border-stone-100 shadow-sm">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-stone-400 mb-3">Good sources for more</h2>
    <ul class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-stone-600">
      <li><a href="https://everout.com/portland/" target="_blank" rel="noopener" class="hover:text-orange-600 underline underline-offset-2">EverOut</a></li>
      <li><a href="https://www.instagram.com/michelevenlee/" target="_blank" rel="noopener" class="hover:text-orange-600 underline underline-offset-2">@michelevenlee on Instagram</a></li>
      <li><a href="https://www.travelportland.com/events/" target="_blank" rel="noopener" class="hover:text-orange-600 underline underline-offset-2">Travel Portland</a></li>
      <li><a href="https://portlandlivingonthecheap.com/" target="_blank" rel="noopener" class="hover:text-orange-600 underline underline-offset-2">Portland Living on the Cheap</a></li>
      <li><a href="https://www.pdxpipeline.com/" target="_blank" rel="noopener" class="hover:text-orange-600 underline underline-offset-2">PDX Pipeline</a></li>
      <li><a href="https://pc-pdx.com/show-guide/" target="_blank" rel="noopener" class="hover:text-orange-600 underline underline-offset-2">PC-PDX</a></li>
      <li><a href="https://pdxparent.com/" target="_blank" rel="noopener" class="hover:text-orange-600 underline underline-offset-2">PDX Parent</a></li>
    </ul>
  </div>

  <!-- Feedback -->
  <section class="bg-white rounded-2xl border border-stone-100 shadow-sm p-6">
    <h2 class="text-lg font-semibold text-stone-900 mb-1" style="font-family: var(--font-serif)">Know something I'm missing?</h2>
    <p class="text-stone-500 text-sm">If you have a suggestion for an event, calendar, or place to add, use <a href="https://docs.google.com/forms/d/e/1FAIpQLScfDTpCGNVIhQgvMdZyv8CPf4QK4oLNiHPv_CrtFAZsaCbsFQ/viewform" target="_blank" rel="noopener" class="text-orange-600 hover:text-orange-700 underline underline-offset-2">this form</a>.</p>
  </section>
</div>

<style>
  .cal-frame { padding-bottom: 80%; height: 0; }
  @media (min-width: 768px) { .cal-frame { padding-bottom: 60%; } }
</style>
