---
import Layout from '../../layouts/Layout.astro';
import EventCard from '../../components/EventCard.astro';
import { CALENDARS, TRIVIA_GROUP, TRIVIA_CALENDARS, PEDALPALOOZA_CALENDAR, ALL_CALENDAR_PAGES, COLOR_MAP } from '../../lib/calendars';
import { fetchCalendarEvents, fetchMultipleCalendars, groupByDate, formatDisplayDate } from '../../lib/google-calendar';

export async function getStaticPaths() {
  return ALL_CALENDAR_PAGES.map(cal => ({ params: { slug: cal.slug } }));
}

const { slug } = Astro.params;
const calConfig = ALL_CALENDAR_PAGES.find(c => c.slug === slug)!;
const colors = COLOR_MAP[calConfig.color] ?? COLOR_MAP['orange'];

// Fetch events for this calendar
let events = [];
if (slug === 'trivia') {
  events = await fetchMultipleCalendars(
    TRIVIA_CALENDARS.map(c => ({ id: c.id, name: c.name, slug: c.slug, color: c.color }))
  );
} else {
  const cal = slug === 'pedalpalooza' ? PEDALPALOOZA_CALENDAR : CALENDARS.find(c => c.slug === slug)!;
  events = await fetchCalendarEvents(cal.id, cal.name, cal.slug, cal.color);
}

const grouped = groupByDate(events);
---

<Layout
  title={calConfig.name}
  description={`Upcoming ${calConfig.name} in Portland, Oregon. ${calConfig.description}`}
>
  <div class="max-w-3xl mx-auto px-4 py-10">

    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-2">
        <span class={`w-3 h-3 rounded-full ${colors.dot}`}></span>
        <h1 class="text-3xl font-semibold text-stone-900" style="font-family: var(--font-serif)">
          {calConfig.name}
        </h1>
      </div>
      {calConfig.description && (
        <p class="text-stone-500 text-sm ml-6">{calConfig.description}</p>
      )}
      <div class="mt-4 ml-6 flex gap-3">
        <a href="/" class="text-xs text-stone-400 hover:text-orange-600 transition-colors">← All calendars</a>
      </div>
    </div>

    <!-- Nav links to other calendars -->
    <div class="flex flex-wrap gap-2 mb-8">
      {ALL_CALENDAR_PAGES.filter(c => c.slug !== slug).map(cal => {
        const c = COLOR_MAP[cal.color] ?? COLOR_MAP['orange'];
        return (
          <a href={`/calendar/${cal.slug}`}
             class={`text-xs px-3 py-1 rounded-full border ${c.border} ${c.text} ${c.bg} hover:opacity-80 transition-opacity`}>
            {cal.name}
          </a>
        );
      })}
    </div>

    <!-- Events -->
    {events.length === 0 ? (
      <p class="text-stone-400 text-sm">No upcoming events found.</p>
    ) : (
      <div>
        {[...grouped.entries()].map(([date, dayEvents]) => (
          <div class="mb-6">
            <h2 class={`text-xs font-semibold uppercase tracking-widest ${colors.text} mb-2`}>
              {formatDisplayDate(date)}
            </h2>
            <div class={`rounded-xl border ${colors.border} ${colors.bg} px-4`}>
              {dayEvents.map(event => <EventCard event={event} showCalendar={slug === 'trivia'} />)}
            </div>
          </div>
        ))}
      </div>
    )}

  </div>

  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": `${calConfig.name} — Portland, OR`,
    "description": calConfig.description,
    "itemListElement": events.map((e, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "item": {
        "@type": "Event",
        "name": e.title,
        "startDate": e.allDay ? e.date : `${e.date}T${e.time}`,
        "location": e.location ? { "@type": "Place", "name": e.location, "address": { "@type": "PostalAddress", "addressLocality": "Portland", "addressRegion": "OR" } } : undefined,
        "url": e.url || e.googleUrl,
        "organizer": { "@type": "Organization", "name": "PDX Events", "url": "https://www.pdx-events.com" },
      }
    }))
  })} />
</Layout>
