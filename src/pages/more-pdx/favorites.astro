---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Portland Favorites" description="Ian's favorite places around Portland, OR.">
  <div class="max-w-3xl mx-auto px-4 py-12">
    <a href="/more-pdx" class="inline-flex items-center gap-1 text-sm text-stone-400 hover:text-stone-700 transition-colors mb-8">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      More PDX
    </a>
    <h1 class="text-4xl font-semibold text-stone-900 mb-3" style="font-family: var(--font-serif)">Portland Favorites</h1>
    <p class="text-stone-500 mb-8">Places around Portland I keep coming back to.</p>

    <div class="p-8 bg-white rounded-2xl border border-stone-100 shadow-sm text-center text-stone-400">
      <p>Content coming soon — migrating from Google Sites.</p>
    </div>
  </div>
</Layout>
