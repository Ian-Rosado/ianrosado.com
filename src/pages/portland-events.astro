---
import Layout from '../layouts/Layout.astro';
import EventsView from '../../src-shared/components/EventsView.astro';
---

<Layout
  title="Portland Events"
  description="A curated Portland events calendar — things to do in Portland, OR including farmers markets, trivia nights, Pedalpalooza, and local staples. Updated regularly."
  pageClass="page-events"
>
  <div class="max-w-5xl mx-auto px-4 pt-8 pb-0">
    <p class="text-sm text-stone-400">
      These calendars also live at their own dedicated site —
      <a href="https://www.pdx-events.com" target="_blank" rel="noopener" class="text-orange-600 hover:text-orange-700 underline underline-offset-2">pdx-events.com</a>.
    </p>
  </div>
  <EventsView />
</Layout>
