---
import Layout from '../layouts/Layout.astro';
import EventCard from '../components/EventCard.astro';
import { CALENDARS, TRIVIA_GROUP, TRIVIA_CALENDARS, PEDALPALOOZA_CALENDAR, COLOR_MAP } from '../lib/calendars';
import { fetchCalendarEvents, fetchMultipleCalendars, groupByDate, formatDisplayDate } from '../lib/google-calendar';

// Fetch everything
const [eventsEvents, musicEvents, comedyEvents, karaokeEvents, marketsEvents, triviaEvents, pedalaEvents] =
  await Promise.all([
    fetchCalendarEvents(CALENDARS[0].id, CALENDARS[0].name, CALENDARS[0].slug, CALENDARS[0].color),
    fetchCalendarEvents(CALENDARS[1].id, CALENDARS[1].name, CALENDARS[1].slug, CALENDARS[1].color),
    fetchCalendarEvents(CALENDARS[2].id, CALENDARS[2].name, CALENDARS[2].slug, CALENDARS[2].color),
    fetchCalendarEvents(CALENDARS[3].id, CALENDARS[3].name, CALENDARS[3].slug, CALENDARS[3].color),
    fetchCalendarEvents(CALENDARS[4].id, CALENDARS[4].name, CALENDARS[4].slug, CALENDARS[4].color),
    fetchMultipleCalendars(TRIVIA_CALENDARS.map(c => ({ id: c.id, name: c.name, slug: c.slug, color: c.color }))),
    fetchCalendarEvents(PEDALPALOOZA_CALENDAR.id, PEDALPALOOZA_CALENDAR.name, PEDALPALOOZA_CALENDAR.slug, PEDALPALOOZA_CALENDAR.color),
  ]);

const allEvents = [
  ...eventsEvents, ...musicEvents, ...comedyEvents, ...karaokeEvents,
  ...marketsEvents, ...triviaEvents, ...pedalaEvents,
].sort((a, b) => a.date.localeCompare(b.date) || a.time.localeCompare(b.time));

const grouped = groupByDate(allEvents);

// Category filter options
const categories = [
  { slug: 'events',          label: 'Events',         color: 'orange' },
  { slug: 'live-music',      label: 'Live Music',     color: 'yellow' },
  { slug: 'comedy',          label: 'Comedy',         color: 'purple' },
  { slug: 'karaoke',         label: 'Karaoke',        color: 'pink' },
  { slug: 'farmers-markets', label: 'Farmers Markets',color: 'green' },
  { slug: 'trivia',          label: 'Trivia',         color: 'blue' },
  { slug: 'pedalpalooza',    label: 'Pedalpalooza',   color: 'teal' },
];

const totalCount = allEvents.length;
const freeCount = allEvents.filter(e => e.costClass === 'free').length;
---

<Layout
  title="Browse Events"
  description="Browse and filter upcoming Portland events by category and cost — free events, live music, comedy, markets, trivia, and more."
>
  <div class="max-w-3xl mx-auto px-4 py-8">

    <h1 class="text-3xl font-semibold text-stone-900 mb-1" style="font-family: var(--font-serif)">Browse Events</h1>
    <p class="text-stone-500 text-sm mb-6">
      <span id="result-count">{totalCount}</span> upcoming events · {freeCount} free
    </p>

    <!-- Filter bar -->
    <div class="sticky top-[57px] z-40 bg-white/95 backdrop-blur py-3 -mx-4 px-4 border-b border-stone-100 mb-6">
      <!-- Search -->
      <input
        type="search"
        id="search-input"
        placeholder="Search events or venues…"
        class="w-full mb-3 px-3 py-2 text-sm rounded-lg border border-stone-200 focus:outline-none focus:ring-2 focus:ring-orange-300"
      />

      <!-- Cost toggle -->
      <div class="flex flex-wrap items-center gap-2 mb-2">
        <span class="text-xs font-semibold text-stone-400 uppercase tracking-wide mr-1">Cost</span>
        <button class="filter-pill" data-filter="cost" data-value="all" aria-pressed="true">All</button>
        <button class="filter-pill" data-filter="cost" data-value="free" aria-pressed="false">Free only</button>
        <button class="filter-pill" data-filter="cost" data-value="paid" aria-pressed="false">Paid</button>
      </div>

      <!-- Category toggles -->
      <div class="flex flex-wrap items-center gap-2">
        <span class="text-xs font-semibold text-stone-400 uppercase tracking-wide mr-1">Type</span>
        <button class="filter-pill" data-filter="category" data-value="all" aria-pressed="true">All</button>
        {categories.map(cat => (
          <button class="filter-pill" data-filter="category" data-value={cat.slug} aria-pressed="false">
            {cat.label}
          </button>
        ))}
      </div>
    </div>

    <!-- Events grouped by date -->
    <div id="events-list">
      {[...grouped.entries()].map(([date, dayEvents]) => (
        <div class="date-group mb-6" data-date={date}>
          <h2 class="date-heading text-xs font-semibold uppercase tracking-widest text-stone-500 mb-2">
            {formatDisplayDate(date)}
          </h2>
          <div class="rounded-xl border border-stone-100 px-4">
            {dayEvents.map(event => <EventCard event={event} showCalendar={true} />)}
          </div>
        </div>
      ))}
    </div>

    <!-- No results message -->
    <p id="no-results" class="hidden text-center text-stone-400 text-sm py-12">
      No events match your filters. <button id="clear-filters" class="text-orange-600 underline">Clear filters</button>
    </p>

  </div>

  <style>
    .filter-pill {
      font-size: 0.75rem;
      padding: 0.25rem 0.75rem;
      border-radius: 9999px;
      border: 1px solid rgb(231 229 228);
      color: rgb(120 113 108);
      background: white;
      transition: all 0.12s;
      cursor: pointer;
    }
    .filter-pill:hover { border-color: rgb(251 146 60); color: rgb(234 88 12); }
    .filter-pill[aria-pressed="true"] {
      background: rgb(234 88 12);
      border-color: rgb(234 88 12);
      color: white;
    }
  </style>

  <script>
    const state = { cost: 'all', category: 'all', search: '' };
    const cards = Array.from(document.querySelectorAll<HTMLElement>('.event-card'));
    const groups = Array.from(document.querySelectorAll<HTMLElement>('.date-group'));
    const countEl = document.getElementById('result-count');
    const noResults = document.getElementById('no-results');
    const listEl = document.getElementById('events-list');

    function apply() {
      let visible = 0;
      for (const card of cards) {
        const cost = card.dataset.cost ?? 'unknown';
        const category = card.dataset.category ?? '';
        const title = card.dataset.title ?? '';
        const location = card.dataset.location ?? '';

        const okCost = state.cost === 'all' || cost === state.cost;
        const okCat = state.category === 'all' || category === state.category;
        const okSearch = !state.search ||
          title.includes(state.search) || location.includes(state.search);

        const show = okCost && okCat && okSearch;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      }

      // Hide empty date groups
      for (const group of groups) {
        const anyVisible = group.querySelectorAll<HTMLElement>('.event-card')
          .length && Array.from(group.querySelectorAll<HTMLElement>('.event-card'))
          .some(c => c.style.display !== 'none');
        group.style.display = anyVisible ? '' : 'none';
      }

      if (countEl) countEl.textContent = String(visible);
      if (noResults) noResults.classList.toggle('hidden', visible !== 0);
      if (listEl) listEl.classList.toggle('hidden', visible === 0);
    }

    // Pill buttons
    document.querySelectorAll<HTMLElement>('.filter-pill').forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter as 'cost' | 'category';
        const value = btn.dataset.value!;
        state[filter] = value;
        // Update pressed state within the same filter group
        document.querySelectorAll<HTMLElement>(`.filter-pill[data-filter="${filter}"]`)
          .forEach(b => b.setAttribute('aria-pressed', String(b.dataset.value === value)));
        apply();
      });
    });

    // Search
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    searchInput?.addEventListener('input', () => {
      state.search = searchInput.value.trim().toLowerCase();
      apply();
    });

    // Clear filters
    document.getElementById('clear-filters')?.addEventListener('click', () => {
      state.cost = 'all'; state.category = 'all'; state.search = '';
      if (searchInput) searchInput.value = '';
      document.querySelectorAll<HTMLElement>('.filter-pill').forEach(b =>
        b.setAttribute('aria-pressed', String(b.dataset.value === 'all')));
      apply();
    });
  </script>
</Layout>
