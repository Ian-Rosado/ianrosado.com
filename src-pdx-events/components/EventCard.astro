---
import type { CalEvent } from '../lib/google-calendar';
import { formatDisplayDate } from '../lib/google-calendar';
import { COLOR_MAP } from '../lib/calendars';

interface Props {
  event: CalEvent;
  showCalendar?: boolean;
}
const { event: e, showCalendar = false } = Astro.props;
const colors = COLOR_MAP[e.color] ?? COLOR_MAP['orange'];
const displayDate = formatDisplayDate(e.date);
const link = e.url || e.googleUrl;
---

<article
  class="event-card flex gap-4 py-4 border-b border-stone-100 last:border-0"
  data-cost={e.costClass}
  data-category={e.calendarSlug}
  data-title={e.title.toLowerCase()}
  data-location={(e.location || '').toLowerCase()}
>
  <!-- Date badge: "Jun / 7 / Sat" -->
  <div class="flex-shrink-0 w-12 text-center pt-0.5">
    <div class="text-xs text-stone-400 uppercase tracking-wide leading-none">
      {displayDate.split(' ')[1]}
    </div>
    <div class={`text-2xl font-bold leading-tight ${colors.text}`}>
      {displayDate.split(' ')[2]}
    </div>
    <div class="text-xs text-stone-400 uppercase tracking-wide leading-none">
      {displayDate.split(',')[0]}
    </div>
  </div>

  <!-- Event details -->
  <div class="flex-1 min-w-0">
    <h3 class="text-sm font-semibold text-stone-900 leading-snug">
      {link ? (
        <a href={link} target="_blank" rel="noopener noreferrer"
           class="hover:text-orange-600 transition-colors">
          {e.title}
        </a>
      ) : e.title}
    </h3>

    <div class="mt-1 flex flex-wrap gap-x-3 gap-y-0.5 text-xs text-stone-500">
      {e.time && (
        <span>{e.time}{e.endTime && e.endTime !== e.time ? ` – ${e.endTime}` : ''}</span>
      )}
      {e.location && (
        <span class="truncate max-w-[200px]" title={e.location}>📍 {e.location}</span>
      )}
      {e.costClass === 'free' ? (
        <span class="font-semibold text-green-700 bg-green-50 px-1.5 rounded">Free</span>
      ) : e.cost ? (
        <span class="font-medium text-stone-600">{e.cost}</span>
      ) : null}
      {showCalendar && (
        <span class={`${colors.text} font-medium`}>{e.calendarName}</span>
      )}
    </div>
  </div>

  <!-- External link icon -->
  {link && (
    <a href={link} target="_blank" rel="noopener noreferrer"
       class="flex-shrink-0 self-center text-stone-300 hover:text-orange-500 transition-colors"
       aria-label={`Details for ${e.title}`}>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
      </svg>
    </a>
  )}
</article>
