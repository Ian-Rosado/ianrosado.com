---
import Layout from '../layouts/Layout.astro';
import EventsCalendars from '../../src/components/pdx/EventsCalendars.astro';
---

<Layout
  title="PDX Events"
  description="A curated Portland events calendar — things to do in Portland, OR including farmers markets, trivia nights, Pedalpalooza, and local staples. Updated regularly."
  pageClass="page-events"
  ogImage="/images/IMG_1945.jpg"
>
  <!-- Hero image -->
  <div class="w-full relative" style="height: 420px; overflow: hidden;">
    <img
      src="/images/IMG_1945.jpg"
      alt="Portland, Oregon skyline and cityscape"
      class="w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent flex items-end">
      <div class="px-6 pb-8 max-w-5xl mx-auto w-full">
        <h1 class="text-4xl font-semibold text-white drop-shadow" style="font-family: var(--font-serif)">Portland Events</h1>
        <p class="text-white/80 text-lg mt-2 max-w-xl drop-shadow">Curated calendars for things happening around Portland — events, markets, trivia, rides, and more.</p>
      </div>
    </div>
  </div>

  <EventsCalendars />
</Layout>
