---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About" description="About Ian Rosado — data engineer based in Portland, OR." pageClass="page-about">
  <div class="max-w-2xl mx-auto px-4 py-12">
    <header class="mb-10">
      <h1 class="text-4xl font-semibold text-stone-900 mb-3" style="font-family: var(--font-serif)">About</h1>
    </header>

    <div class="bg-white rounded-2xl border border-stone-100 shadow-sm p-8">
      <!-- Profile photo placeholder — replace src with actual photo path -->
      <div class="w-24 h-24 rounded-full bg-stone-200 mb-6 overflow-hidden">
        <!-- <img src="/images/ian.jpg" alt="Ian Rosado" class="w-full h-full object-cover" /> -->
      </div>

      <p class="text-stone-600 leading-relaxed mb-6">
        I'm a data engineer based in Portland, OR. I work on analytics infrastructure and spend my off-hours exploring the city,
        baking, and going on the occasional road trip.
      </p>

      <h2 class="text-xs font-semibold uppercase tracking-widest text-stone-400 mb-4">Find me</h2>
      <ul class="space-y-3">
        <li>
          <a href="mailto:ian.p.rosado@gmail.com" class="flex items-center gap-3 text-stone-700 hover:text-orange-600 transition-colors group">
            <span class="w-8 h-8 rounded-full bg-stone-100 group-hover:bg-orange-50 flex items-center justify-center transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
