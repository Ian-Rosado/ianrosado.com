---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const recipes = await getCollection('recipes');
recipes.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Recipes" description="Recipes from Ian Rosado — baking, cooking, and the science behind it." pageClass="page-recipes">
  <div class="max-w-5xl mx-auto px-4 py-12">
    <header class="mb-10">
      <h1 class="text-4xl font-semibold text-stone-900 mb-3" style="font-family: var(--font-serif)">Recipes</h1>
      <p class="text-stone-500 text-lg max-w-xl">
        I enjoy cooking and I love baking. No long preambles — just the recipe, the steps, and a little science at the end.
      </p>
    </header>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {recipes.map(recipe => (
        <a href={`/recipes/${recipe.id}`} class="group block bg-white rounded-2xl overflow-hidden border border-stone-100 shadow-sm hover:shadow-md hover:border-orange-200 transition-all">
          {recipe.data.coverImage ? (
            <div class="aspect-[4/3] overflow-hidden bg-orange-50">
              <img
                src={recipe.data.coverImage}
                alt={recipe.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            </div>
          ) : (
            <div class="aspect-[4/3] bg-orange-50 flex items-center justify-center text-orange-200">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
          )}
          <div class="p-4">
            <div class="flex flex-wrap gap-1 mb-2">
              {recipe.data.tags.map((tag: string) => (
                <span class="text-xs px-2 py-0.5 bg-orange-50 text-orange-700 rounded-full">{tag}</span>
              ))}
            </div>
            <h2 class="font-medium text-stone-900 group-hover:text-orange-600 transition-colors leading-snug" style="font-family: var(--font-serif)">{recipe.data.title}</h2>
            <p class="text-sm text-stone-400 mt-1">{recipe.data.description}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
