---
import type { CalEvent } from '../lib/google-calendar';
import { COLOR_MAP } from '../lib/calendars';

interface Props {
  event: CalEvent;
}
const { event: e } = Astro.props;
const colors = COLOR_MAP[e.color] ?? COLOR_MAP['orange'];
const link = e.url || e.googleUrl;
---

<!--
  Compact single-line event row. Designed to pack many events into a small
  vertical space. data-* attributes drive client-side filtering in EventsView.
-->
<li
  class="event-row flex items-baseline gap-2 py-1.5 px-2 -mx-2 rounded hover:bg-stone-50 transition-colors"
  data-cost={e.costClass}
  data-category={e.calendarSlug}
  data-genres={(e.genres || []).join(',')}
  data-title={e.title.toLowerCase()}
  data-location={(e.location || '').toLowerCase()}
>
  <!-- Category dot -->
  <span class={`mt-1.5 flex-shrink-0 w-2 h-2 rounded-full ${colors.dot}`} title={e.calendarName}></span>

  <!-- Time (fixed width so titles align) -->
  <span class="flex-shrink-0 w-16 text-xs tabular-nums text-stone-400 text-right">
    {e.allDay ? 'all day' : e.time}
  </span>

  <!-- Title + venue -->
  <span class="flex-1 min-w-0 text-sm leading-snug">
    {link ? (
      <a href={link} target="_blank" rel="noopener noreferrer" class="text-stone-900 hover:text-orange-600 transition-colors font-medium">
        {e.title}
      </a>
    ) : (
      <span class="text-stone-900 font-medium">{e.title}</span>
    )}
    {e.location && (
      <span class="text-stone-400"> · {e.location}</span>
    )}
  </span>

  <!-- Cost -->
  {e.costClass === 'free' ? (
    <span class="flex-shrink-0 text-xs font-semibold text-green-700">Free</span>
  ) : e.cost ? (
    <span class="flex-shrink-0 text-xs text-stone-500">{e.cost}</span>
  ) : null}
</li>
