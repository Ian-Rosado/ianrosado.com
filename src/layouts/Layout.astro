---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  pageClass?: string;
}

const { title, description = "Ian Rosado's personal site — Portland events, recipes, and more.", pageClass = 'page-home' } = Astro.props;
const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/portland-events', label: 'Portland Events' },
  { href: '/more-pdx', label: 'More PDX' },
  { href: '/recipes', label: 'Recipes' },
  { href: '/my-life', label: 'My Life' },
  { href: '/about', label: 'About' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title === 'Home' ? 'Ian Rosado' : `${title} | Ian Rosado`}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Lora:ital,wght@0,600;1,400&display=swap" rel="stylesheet" />
  </head>
  <body class={`text-stone-900 min-h-screen ${pageClass}`} style="font-family: var(--font-sans)">
    <header class="bg-white border-b border-stone-200 sticky top-0 z-50">
      <nav class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="text-xl font-semibold text-stone-800 hover:text-stone-600 transition-colors" style="font-family: var(--font-serif)">
          Ian Rosado
        </a>
        <ul class="hidden md:flex items-center gap-6 text-sm font-medium text-stone-600">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class={`hover:text-orange-600 transition-colors pb-0.5 ${isActive(link.href) ? 'text-orange-600 border-b-2 border-orange-600' : ''}`}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
        <button class="md:hidden p-2 text-stone-600" aria-label="Open menu" id="menu-btn">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </nav>
      <div class="md:hidden hidden border-t border-stone-100 bg-white" id="mobile-menu">
        <ul class="px-4 py-3 space-y-3 text-sm font-medium text-stone-600">
          {navLinks.map(link => (
            <li>
              <a href={link.href} class={`block py-1 hover:text-orange-600 ${isActive(link.href) ? 'text-orange-600 font-semibold' : ''}`}>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-stone-200 mt-16 py-8 text-center text-sm text-stone-400">
      <p>
        &copy; {new Date().getFullYear()} Ian Rosado &middot;
        <a href="mailto:ian.p.rosado@gmail.com" class="hover:text-orange-600 transition-colors">ian.p.rosado@gmail.com</a>
      </p>
    </footer>

    <script>
      const btn = document.getElementById('menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
    </script>
  </body>
</html>
