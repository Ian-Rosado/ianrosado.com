---
import '../../src/styles/global.css';

interface Props {
  title: string;
  description?: string;
  pageClass?: string;
  ogImage?: string;
}

const {
  title,
  description = 'PDX Events — curated Portland event calendars, favorites, and pickup soccer.',
  pageClass = 'page-events',
  ogImage,
} = Astro.props;

const pathname = Astro.url.pathname;
const siteUrl = 'https://www.pdx-events.com';
const canonicalUrl = `${siteUrl}${pathname}`;
const pageTitle = title === 'PDX Events' ? 'PDX Events' : `${title} | PDX Events`;
const ogImageUrl = ogImage ? `${siteUrl}${ogImage}` : `${siteUrl}/og-default.jpg`;

const navLinks = [
  { href: '/', label: 'Events' },
  { href: '/favorites', label: 'Favorites' },
  { href: '/pickup-soccer', label: 'Pickup Soccer' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Primary meta -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="PDX Events" />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicon (shared from public/) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-31XJQKCJD6"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-31XJQKCJD6');
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Lora:ital,wght@0,600;1,400&display=swap" rel="stylesheet" />
  </head>
  <body class={`text-stone-900 min-h-screen ${pageClass}`} style="font-family: var(--font-sans)">
    <header class="bg-white border-b border-stone-200 sticky top-0 z-50">
      <nav class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="text-xl font-semibold text-stone-800 hover:text-stone-600 transition-colors" style="font-family: var(--font-serif)">
          PDX Events
        </a>
        <ul class="hidden md:flex items-center gap-6 text-sm font-medium text-stone-600">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class={`hover:text-orange-600 transition-colors pb-0.5 ${isActive(link.href) ? 'text-orange-600 border-b-2 border-orange-600' : ''}`}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
        <button class="md:hidden p-2 text-stone-600" aria-label="Open menu" id="menu-btn">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </nav>
      <div class="md:hidden hidden border-t border-stone-100 bg-white" id="mobile-menu">
        <ul class="px-4 py-3 space-y-3 text-sm font-medium text-stone-600">
          {navLinks.map(link => (
            <li>
              <a href={link.href} class={`block py-1 hover:text-orange-600 ${isActive(link.href) ? 'text-orange-600 font-semibold' : ''}`}>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-stone-200 mt-16 py-8 text-center text-sm text-stone-400">
      <p>
        PDX Events &middot; Curated by
        <a href="https://www.ianrosado.com" class="hover:text-orange-600 transition-colors">Ian Rosado</a>
      </p>
    </footer>

    <script>
      const btn = document.getElementById('menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
    </script>
  </body>
</html>
