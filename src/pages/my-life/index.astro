---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="My Life" description="Personal content — sabbatical road trip and other adventures." pageClass="page-mylife">
  <div class="max-w-5xl mx-auto px-4 py-12">
    <header class="mb-10">
      <h1 class="text-4xl font-semibold text-stone-900 mb-3" style="font-family: var(--font-serif)">My Life</h1>
      <p class="text-stone-500 text-lg max-w-xl">Adventures, travels, and personal projects.</p>
    </header>

    <div class="grid sm:grid-cols-2 gap-5">
      <a href="/my-life/sabbatical" class="group block bg-white rounded-2xl border border-stone-100 shadow-sm hover:shadow-md transition-shadow p-6">
        <h2 class="text-xl font-semibold text-stone-900 mb-2 group-hover:text-stone-600 transition-colors" style="font-family: var(--font-serif)">Sabbatical Road Trip</h2>
        <p class="text-stone-500 text-sm">40+ days from Oregon through California, Utah, Arizona, New Mexico, and Texas.</p>
      </a>
    </div>
  </div>
</Layout>
